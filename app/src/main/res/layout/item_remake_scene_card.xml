<?xml version="1.0" encoding="utf-8"?>
<!--
  US-D-028-REMAKE-SCENE-PICKER

  Single scene card in the 2-column grid. Shows the scene name (title)
  and short description. The thumbnail (exampleImageUrl) is intentionally
  omitted from this minimal layout because the CDN URL is null in the
  seed; the card stays demoable without an image, and a future iteration
  can add a placeholder ImageView once the CDN warms up.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp"
    android:layout_margin="6dp"
    android:background="@drawable/bg_remake_scene_card"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/tv_scene_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_scene_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="12sp"
        android:alpha="0.7"
        android:maxLines="3"
        android:ellipsize="end" />
</LinearLayout>
